<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvNoSoal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Soal 1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#050505"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvPertanyaan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pertanyaan akan tampil di sini"
            android:textSize="18sp"
            android:textColor="#050505"
            android:layout_marginBottom="16dp" />

        <RadioGroup
            android:id="@+id/rgPilihan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbPilihanA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilihan A"
                android:textColor="#050505" />

            <RadioButton
                android:id="@+id/rbPilihanB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilihan B"
                android:textColor="#050505" />

            <RadioButton
                android:id="@+id/rbPilihanC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilihan C"
                android:textColor="#050505" />

            <RadioButton
                android:id="@+id/rbPilihanD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilihan D"
                android:textColor="#050505" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvHasil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00796B"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            android:gravity="center" />


        <Button
            android:id="@+id/btnJawab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jawab"
            android:layout_marginTop="24dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnPrevSoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kembali ke soal sebelumnya"
            android:layout_marginTop="16dp"
            android:backgroundTint="#9E9E9E"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnBackSoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kembali ke menu utama"
            android:layout_marginTop="8dp"
            android:backgroundTint="#757575"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
